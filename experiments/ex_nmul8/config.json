{
  "factorflow": {
    "main_cli": "./FactorFlow/main_cli.py",
    "architecture": "eyeriss-conv",
    "args": [4,4,4,4,3,3],
    "force": false
  },
  "bambu": {
    "clock_period": 5,
    "compiler": "I386_GCC8",
    "opt_level": 3,
    "v": 4,
    "extra_args": ["-C=__float_mul=8"]
  },
  "layout": {
    "ff_output_dir": "FF_output",
    "bambu_output_dir": "Bambu_outputs"
  }
}
